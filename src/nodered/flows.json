    {
        "id": "f8653eba5092ec9b",
        "type": "function",
        "z": "d6d692dd7d1fe414",
        "name": "simulaSisma",
        "func": "// Recupero il nome del sismografo dal nodo Inject\nconst deviceID = msg.payload;\n\n// Verifico che il payload non sia vuoto\nif (!deviceID || typeof deviceID !== 'string') {\n    node.error(\"Errore: Il nodo Inject deve inviare il nome del sismografo come stringa!\");\n    return null;\n}\n\n// Simulo la raffica di tilt (10 messaggi, uno ogni 500ms)\nfor (let i = 0; i < 10; i++) {\n    setTimeout(() => {\n        // Costruisco il payload per AWS\n        let simulatedPayload = {\n            \"deviceId\": deviceID,\n            \"timestamp\": Math.floor(Date.now() / 1000)\n        };\n\n        // Costruisco il topic dinamico: devices/NOME_SISMOGRAFO/tilt\n        let topicDinamico = \"devices/\" + deviceID + \"/tilt\";\n\n        // Invio il messaggio al nodo MQTT Out\n        node.send({\n            topic: topicDinamico,\n            payload: simulatedPayload\n        });\n\n    }, i * 500);\n}\n\n// Log di controllo nel debug di Node-RED\nnode.warn(\"Simulazione avviata per il dispositivo: \" + deviceID);\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 530,
        "y": 240,
        "wires": [
            [
                "0b068d6e81f50d1a"
            ]
        ]
    },
