        "name": "function 9",
        "func": "// 1. Recupera i valori dalle VARIABILI DI FLUSSO (dove li hai salvati dai form)\nvar id = flow.get(\"deviceId\");\nvar area = flow.get(\"areaId\");\n\n// 2. Controllo di sicurezza: se i campi sono vuoti o indefiniti, ferma tutto e avvisa\nif (!id || id === \"\") {\n    node.error(\"ERRORE: deviceId è vuoto!\");\n    node.status({ fill: \"red\", shape: \"ring\", text: \"deviceId vuoto!\" });\n    return null; // Interrompe il flusso\n}\nif (!area || area === \"\") {\n    node.error(\"ERRORE: areaId è vuoto!\");\n    node.status({ fill: \"red\", shape: \"ring\", text: \"areaId vuoto!\" });\n    return null; // Interrompe il flusso\n}\n\n// 3. Prepara i parametri DIRETTAMENTE SU MSG, non in msg.payload!\nmsg.TableName = \"SensorsRegistry\";\n\nmsg.Item = {\n    \"deviceId\": { \"S\": String(id) },\n    \"areaId\": { \"S\": String(area) }\n};\n\nreturn msg;",
