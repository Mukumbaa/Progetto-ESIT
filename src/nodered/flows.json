        "name": "function 11",
        "func": "// Recupera i dati dal flow context\nvar areaId = flow.get(\"areaId\") || \"GLOBAL\";\nvar threshold = flow.get(\"tiltThreshold\") || 5;\nvar window = flow.get(\"timeWindow\") || 10;\nvar h1 = flow.get(\"int1\") || 1;\nvar h2 = flow.get(\"int2\") || 12;\nvar h3 = flow.get(\"int3\") || 24;\n\nmsg.Item = {\n        \"areaId\": { \"S\": String(areaId) },\n        // NOTA: Usa \"N\" per i numeri, ma passali come stringhe. \n        // DynamoDB vuole così per il tipo Number.\n        \"tiltThreshold\": { \"N\": String(threshold) },\n        \"timeWindow\":    { \"N\": String(window) },\n        \"int1\":          { \"N\": String(h1) },\n        \"int2\":          { \"N\": String(h2) },\n        \"int3\":          { \"N\": String(h3) }\n    \n};\n\nreturn msg;",
