    {
        "id": "3037a07c1fd46111",
        "type": "function",
        "z": "1574fed41230656a",
        "name": "simulaSisma",
        "func": "// Recuperiamo il nome del sismografo dal nodo Inject\nconst deviceID = msg.payload;\n\n// Verifichiamo che il payload non sia vuoto\nif (!deviceID || typeof deviceID !== 'string') {\n    node.error(\"Errore: Il nodo Inject deve inviare il nome del sismografo come stringa!\");\n    return null;\n}\n\n// Simuliamo la raffica di tilt (10 messaggi, uno ogni 500ms)\nfor (let i = 0; i < 10; i++) {\n    setTimeout(() => {\n        // Costruiamo il payload per AWS\n        let simulatedPayload = {\n            \"deviceId\": deviceID,\n            \"timestamp\": Math.floor(Date.now() / 1000)\n        };\n\n        // Costruiamo il topic dinamico: devices/NOME_SISMOGRAFO/tilt\n        let topicDinamico = \"devices/\" + deviceID + \"/tilt\";\n\n        // Inviamo il messaggio al nodo MQTT Out\n        node.send({\n            topic: topicDinamico,\n            payload: simulatedPayload\n        });\n\n    }, i * 500);\n}\n\n// Log di controllo nel debug di Node-RED\nnode.warn(\"Simulazione avviata per il dispositivo: \" + deviceID);\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 200,
        "wires": [
            [
                "e97dbe56263fbf32"
            ]
        ]
    },
